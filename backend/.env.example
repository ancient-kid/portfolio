# Flask runtime
PORT=5000
FLASK_ENV=development
DEBUG=true

# Required for chat endpoint
GROQ_API_KEY=your_groq_api_key_here

# Optional personality data source
# CHAT_DATA_PATH=data/whatsapp_chats.json
# CHAT_SENDER_NAME=Anurag

# Optional comma-separated CORS origins override
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://anrg.dev,https://www.anrg.dev

# Activity heatmaps
GITHUB_USERNAME=ancient-kid
LEETCODE_USERNAME=
MONKEYTYPE_USERNAME=
# Required for Monkeytype daily activity endpoint
MONKEYTYPE_APE_KEY=
